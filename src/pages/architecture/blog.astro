---
import Layout from '~/layouts/Layout.astro';
import { fetchPosts } from '~/utils/blog';
import Header from '~/components/widgets/Header.astro';
import BlogList from '~/components/blog/List.astro';
import ArchitectureStyles from '~/components/ArchitectureStyles.astro';
import Footer from '~/components/widgets/Footer.astro';

// 別館専用のナビゲーションデータをインポート
import { architectureHeaderData, architectureFooterData } from '~/navigation-architecture';

const allPosts = await fetchPosts();

// 格納場所は混在のまま、コードのフィルターでコラムだけを全件抽出（件数制限なし）
const architectureAllPosts = allPosts
  .filter((post) => post.category?.slug && post.category.slug === 'column')
  .map((post) => ({
    ...post,
    permalink: `/architecture/${post.slug}`,
  }));

const metadata = {
  title: '思想コラム 記事一覧 — e-Shikumi-Labo:architecture',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  {/* 別館専用の配色変数を注入 */}
  <ArchitectureStyles />

  <div class="dark bg-slate-950 text-slate-100 min-h-screen antialiased font-sans">
    {/* 共通ヘッダー */}
    <Header {...(architectureHeaderData as any)} isSticky showToggleTheme homeUrl="/architecture" />

    <main class="py-12">
      {/* ブログ一覧セクション */}
      {/* 🟢 本家と完全に一致させるため、最大幅を max-w-4xl に修正 */}
      <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
        <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-8 border-b border-gray-200 dark:border-slate-800 pb-6">
          <div class="mb-4 md:mb-0">
            <h2 class="text-3xl font-bold tracking-tight dark:text-white font-mono">
              All Articles // 思想コラム一覧
            </h2>
            <p class="text-sm text-primary dark:text-teal-400 font-medium mt-1">
              思想別館のすべての過去記事
            </p>
          </div>
        </div>

        {/* 本家と完全に同じ縦並び（リスト形式）で全件表示 */}
        <BlogList posts={architectureAllPosts} />
      </section>
    </main>

    {/* 共通フッター */}
    <Footer {...architectureFooterData} />
  </div>
</Layout>