---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'e-Shikumi-Labo —「泥臭い手作業」を、きれいに仕組み化',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
<Hero
    actions={[
      { variant: 'primary', text: '初めての方へ', href: '/newcomer' },
      { text: '仕組化実験室を見る', href: '/blog' },
    ]}
  >
    <Fragment slot="title">
      Webデータ取得 × スプレッドシート<br />
      毎日の「手作業コピペ」を、きれいな仕組みに
    </Fragment>

    <Fragment slot="subtitle">
      手作業では追いつかないWebデータの収集・集計をスプレッドシートで自動化。<br />
      本当に集中すべき「考える時間」を生み出します。
    </Fragment>
  </Hero>


  <BlogLatestPosts
    title="ブログ"
    information="Webデータ取得の自動化に関するノウハウを公開しています。"
  />

  <Content
    isReversed
    id="profile"
    title="プロフィール"
    callToAction={{ text: 'プロフィールを見る', href: '/profile', variant: 'primary' }}
    image={{
      src: '~/assets/images/profile.png',
      alt: 'Profile Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        【Webデータ取得・自走力の伴走支援】</h3>
      <p class="mb-4">
        大学での研究以来30年以上、エンジニアとしての仕事の傍ら、業務改善としてExcel VBAコードを多数制作してきました。2014年には自らの輸出ビジネスを機に、GASなどによるWebデータ取得・自動化システムを本格的に構築。同じ悩みを持つ方へツールの提供を始めました。
      </p>
      <p class="mb-4">
        しかし、サイト側の急激なアクセス規制や自動化への防御策により、ツールを丸ごと手渡すだけの自動化が通用しなくなる限界（挫折）を経験します。
      </p>
      <p class="mb-4">
        当ラボでは完成されたツールの「納品」を一切やめました。
      </p>
      <p class="mb-4">
        現在は、AIを味方につけて、**Webデータ取得を自力で構築・維持管理し続ける力（自走力）**を養う伴走支援に特化しています。  
      </p>
    </Fragment>
  </Content>
</Layout>