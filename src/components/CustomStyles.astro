---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(46 125 50);      /* 元の#2d6a4f（メインの緑） */
    --aw-color-secondary: rgb(46 125 50);    /* 元の#1b4332（深い緑） */
    --aw-color-accent: rgb(222 255 154);    /* 元の#deff9a（アクセントのライム） */

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 250 241);   /* 元の#fffaf1（温かみのある白） */

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: black;
      color: snow;
    }
  }

/* ヘッダー全体と、内側の背景パーツをすべて深緑で固定する */
  #header,
  #header.scroll,
  #header > div:first-child {
    background-color: var(--aw-color-secondary) !important;
    background-image: none !important;
    backdrop-filter: none !important; /* すりガラス効果を完全にオフ */
  }

  /* メニューの文字とアイコンを白にする */
  #header a, 
  #header button,
  #header [data-aw-toggle-menu] {
    color: rgb(255 255 255) !important;
  }

  /* ロゴのテキスト（e-Shikumi-labo）も白にする */
  #header a span {
    color: rgb(255 255 255) !important;
  }

  /* ドロップダウンメニューの背景も深緑にする */
  #header ul ul {
    background-color: var(--aw-color-secondary) !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* マウスを乗せた（ホバー）ときは、アクセントのライム緑にする */
  #header a:hover,
  #header button:hover,
  #header a:hover span {
    color: var(--aw-color-accent) !important;
  }

  /* ==========================================
     フッター全体のデザイン調整
     ========================================== */
  /* フッター全体の背景を深緑にする */
  footer {
    background-color: var(--aw-color-secondary) !important;
    border-top: 1px solid rgba(255, 255, 255, 0.1) !important;
  }

  /* フッター内の文字、リンク、コピーライトをすべて白にする */
  footer,
  footer div,
  footer a,
  footer span {
    color: rgb(255 255 255) !important;
  }

  /* フッターのリンクにマウスを乗せた（ホバー）ときはライム緑にする */
  footer a:hover {
    color: var(--aw-color-accent) !important;
    text-decoration: underline;
  }

  /* 右下の「上に戻る」ボタンの色もお好みの緑に合わせる */
  footer button, 
  [data-aw-toggle-color-scheme] {
    color: rgb(255 255 255) !important;
  }
</style>
